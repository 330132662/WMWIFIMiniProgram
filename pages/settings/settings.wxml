<!--pages/settings/settings.wxml-->
<view class='page-header'>
  <text class='page-title'>{{title}}</text>
</view>
<view class='table-title'>
  <text class="text">BleWiFi</text>
</view>
<view class='table-item' bindtap="showDialog">
  <text class="left-text">Organization ID</text>
  <text class="right-text">{{orgId}}</text>
</view>
<view class='table-title'>
  <text class="text">Versions</text>
</view>
<view class='table-item'>
  <text class="left-text">MiniProgram Version</text>
  <text class="right-text">{{version}}</text>
</view>
<block wx:if="{{isShowConfirm}}">
  <view class='toast-box'>
    <view class='toastbg'></view>
    <view class='showToast'>
        <view class='toast-title'>
            <text>Organization ID:</text>
        </view>
        <view class='toast-main'>
          <view class='toast-input'>
            <input placeholder='Organization ID' value="{{orgIdVal}}" bindinput='setValue' maxlength="4"></input>
          </view>
        </view>
        <view class='toast-button'>
          <view class='button1'>
            <button bindtap='cancel'>取消</button>
          </view>
          <view class='button2'>
            <button bindtap='confirmAcceptance'>确定</button>
          </view>
        </view>
    </view> 
  </view>
</block>